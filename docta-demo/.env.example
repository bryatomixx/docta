# Variables de entorno — en local van en supabase/functions/.env
# En Vercel: Settings → Environment Variables (NUNCA en el código del frontend).
# Estas las leen las funciones serverless (api/*.ts), del lado servidor.

# ATTOM Data API
ATTOM_API_KEY=

# Supabase (service role = solo servidor, bypassa RLS)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (Claude — motor de oferta/email)
ANTHROPIC_API_KEY=

# Opcional
# OFFER_FROM_EMAIL=abryan@latinprimefg.com
# OFFER_FACTOR=0.70
